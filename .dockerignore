# ── Version control ──────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Python cache (never needed in image) ─────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.mypy_cache/
.pytest_cache/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Certificates (mounted at runtime via Docker volume) ───────────────────────
certs/

# ── Metrics results — mounted as volume, not baked into image ─────────────────
metrics/results/

metrics/logs/

# ── Log files ─────────────────────────────────────────────────────────────────
logs/
*.log

# ── Mosquitto config (used by broker container, not the app) ──────────────────
mosquitto/

# ── Shell scripts / docs / compose files (not needed inside container) ────────
*.sh
*.md
docker-compose*.yml
.dockerignore

# ── Trigger script (runs outside the container) ───────────────────────────────
trigger.py
